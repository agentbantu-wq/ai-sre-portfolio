[Unit]
Description=Daily AI/SRE Portfolio Project Generator
Documentation=https://github.com/agentbantu-wq/ai-sre-portfolio
After=network.target

[Service]
Type=oneshot
User=%u
WorkingDirectory=%h/VSCode/ai-sre-portfolio
EnvironmentFile=%h/VSCode/ai-sre-portfolio/.env

# Run daily project generation
ExecStart=/home/%u/VSCode/ai-sre-portfolio/scripts/generate.sh

StandardOutput=journal
StandardError=journal

# Restart on failure
Restart=on-failure
RestartSec=300

[Install]
WantedBy=default.target
