# Browser Configuration for Reddit Scraping
# Instead of Reddit API, we use headless browser with your cookies

# Chrome User Data Directory (contains your Reddit login cookies)
# Find this in Chrome: chrome://version/ -> Profile Path
CHROME_USER_DATA_DIR=/home/dj/.config/google-chrome/Default

# Alternative: Export cookies as JSON (if you prefer not to use full profile)
# COOKIES_JSON_PATH=/path/to/reddit_cookies.json

# Browser settings
HEADLESS=true
BROWSER_WAIT_TIME=5

# Optional: Your hourly rate for ROI calculations (default: $50/hour)
# This affects ROI scoring: ROI = prize_pool / (effort_hours * hourly_rate)
HOURLY_RATE=50